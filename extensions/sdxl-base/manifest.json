{
  "id": "sdxl-base",
  "name": "SDXL Base",
  "type": "model",
  "description": "Self-contained SDXL Base model extension scaffold for local text-to-image and image-to-image workflows.",
  "version": "0.1.0",
  "author": "Standalone Extension",
  "generator_class": "SDXLBaseGenerator",
  "tags": [
    "text-to-image",
    "image-to-image",
    "sdxl",
    "local"
  ],
  "nodes": [
    {
      "id": "text-to-image",
      "name": "Text to Image",
      "input": "text",
      "output": "image",
      "hf_repo": "stabilityai/stable-diffusion-xl-base-1.0",
      "download_check": "model_index.json",
      "params_schema": [
        {
          "id": "prompt",
          "label": "Prompt",
          "type": "string",
          "default": "",
          "tooltip": "Prompt text for SDXL base generation."
        },
        {
          "id": "negative_prompt",
          "label": "Negative Prompt",
          "type": "string",
          "default": "",
          "tooltip": "Optional prompt describing what to avoid."
        },
        {
          "id": "width",
          "label": "Width",
          "type": "int",
          "default": 1024,
          "min": 64,
          "max": 2048
        },
        {
          "id": "height",
          "label": "Height",
          "type": "int",
          "default": 1024,
          "min": 64,
          "max": 2048
        },
        {
          "id": "steps",
          "label": "Steps",
          "type": "int",
          "default": 30,
          "min": 1,
          "max": 150
        },
        {
          "id": "guidance_scale",
          "label": "Guidance Scale",
          "type": "float",
          "default": 5.0,
          "min": 0,
          "max": 50,
          "tooltip": "Lower values are often enough for SDXL base."
        },
        {
          "id": "seed",
          "label": "Seed",
          "type": "int",
          "default": 42,
          "min": 0,
          "max": 2147483647
        }
      ]
    },
    {
      "id": "image-to-image",
      "name": "Image to Image",
      "input": "image",
      "output": "image",
      "hf_repo": "stabilityai/stable-diffusion-xl-base-1.0",
      "download_check": "model_index.json",
      "params_schema": [
        {
          "id": "prompt",
          "label": "Prompt",
          "type": "string",
          "default": "",
          "tooltip": "Optional text guidance for the edit pass."
        },
        {
          "id": "negative_prompt",
          "label": "Negative Prompt",
          "type": "string",
          "default": "",
          "tooltip": "Optional prompt describing what to avoid during the edit."
        },
        {
          "id": "width",
          "label": "Width",
          "type": "int",
          "default": 1024,
          "min": 64,
          "max": 2048
        },
        {
          "id": "height",
          "label": "Height",
          "type": "int",
          "default": 1024,
          "min": 64,
          "max": 2048
        },
        {
          "id": "strength",
          "label": "Strength",
          "type": "float",
          "default": 0.7,
          "min": 0,
          "max": 1,
          "tooltip": "Controls how much the source image is changed."
        },
        {
          "id": "steps",
          "label": "Steps",
          "type": "int",
          "default": 30,
          "min": 1,
          "max": 150
        },
        {
          "id": "guidance_scale",
          "label": "Guidance Scale",
          "type": "float",
          "default": 5.0,
          "min": 0,
          "max": 50,
          "tooltip": "Lower values are often enough for SDXL base."
        },
        {
          "id": "seed",
          "label": "Seed",
          "type": "int",
          "default": 42,
          "min": 0,
          "max": 2147483647
        }
      ]
    }
  ]
}
